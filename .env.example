# ── Server de IMPORT subiecte — variabile de mediu ──
# Local: copiaza in  import/.env  si completeaza.
# Render: seteaza-le in dashboard (Environment), NU pune fisierul .env in repo.

# Supabase — OBLIGATORIU (upload fisiere + inserare materiale).
# URL-ul si cheia "anon/publishable" (nu e secreta; scrierea e protejata de tokenul profesorului).
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Cheia Gemini (Google AI Studio) — OPTIONAL.
# Fara ea, chatul cade pe filtrarea determinista (merge oricum). Bara de filtre nu are nevoie de ea.
GEMINI_API_KEY=

# Domeniul site-ului, pentru CORS (ex. https://smart-learning-cnmsm.ro).
# Poti pune mai multe separate prin virgula. Nesetat = permite orice origine (doar local/test).
CORS_ORIGIN=

# Portul e setat automat de Render (PORT). Local, implicit 3040 (sau IMPORT_PORT).
